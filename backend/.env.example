# Server
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Database
# Prefer DATABASE_URL on Render or other managed PostgreSQL providers.
# If omitted, the app falls back to DB_* or PG* variables.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key
REFRESH_TOKEN_EXPIRY=30d

# Deriv API
DERIV_API_URL=wss://ws.derivws.com/websockets/v3
DERIV_APP_ID=33eUdlaPLj4gee5BGCXvd

# Encryption
ENCRYPTION_KEY=32_character_hex_key_for_encryption
ENCRYPTION_IV=16_character_hex_iv

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=your_session_secret_key

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Stripe (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Mpesa (optional)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dr.drenj@gmail.com
SMTP_PASSWORD=your_app_password

# Logging
LOG_LEVEL=info
