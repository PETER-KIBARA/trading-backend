FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY backend/package*.json ./backend/
WORKDIR /app/backend
RUN npm ci

# Build backend
COPY backend/src ./src
COPY backend/tsconfig.json ./
RUN npm run build

# Switch working directory
WORKDIR /app

# Setup environment
ENV NODE_ENV=production
ENV PORT=5000

EXPOSE 5000

# Start application
CMD ["node", "backend/dist/index.js"]
